# ── Groq (LLM — FREE, very fast) ─────────────────────────────────────────────
# Get key at console.groq.com — free tier: 14,400 req/day, 131K context
GROQ_API_KEY=gsk_...
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# ── Google Gemini (embeddings only — FREE) ────────────────────────────────────
# Get key at aistudio.google.com — used ONLY for text-embedding-004 (768 dims)
GEMINI_API_KEY=AIza...
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=runbookiq
POSTGRES_USER=runbookiq
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://runbookiq:changeme@localhost:5432/runbookiq

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Slack (optional) ──────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Zabbix (optional) ─────────────────────────────────────────────────────────
ZABBIX_API_URL=http://zabbix.internal/api_jsonrpc.php
ZABBIX_USER=Admin
ZABBIX_PASSWORD=zabbix

# ── Kubernetes (optional) ─────────────────────────────────────────────────────
# Leave blank to use in-cluster service account; set to path for kubeconfig
K8S_KUBECONFIG=
K8S_NAMESPACE=default

# ── Prometheus / Alertmanager (optional) ──────────────────────────────────────
PROMETHEUS_ALERTMANAGER_URL=http://alertmanager:9093

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-random-32-char-string
LOG_LEVEL=INFO
DEFAULT_TENANT_ID=default

# ── Upload ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50
